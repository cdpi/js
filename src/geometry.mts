
const _TWO_PI = 2 * Math.PI;

/////////////////////////////////////////////////////////////////////////////////////////////////////////////

class Point
	{
	x:number;
	y:number;

	constructor(x:number, y:number)
		{
		this.x = x;
		this.y = y;
		}

	toString()
		{
		return `(${this.x}, ${this.y})`;
		}
	}

